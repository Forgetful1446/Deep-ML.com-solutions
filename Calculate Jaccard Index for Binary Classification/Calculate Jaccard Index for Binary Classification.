import numpy as np

def jaccard_index(y_true, y_pred):
    TP = 0
    FP = 0
    TN = 0
    for i in range(len(y_true)):
        if (y_pred[i] == 1 and y_true[i] == 1):
            TP += 1
        elif(y_pred[i] == 0 and y_true[i] == 1) :
            FP += 1
        elif(y_pred[i] == 1 and y_true[i] == 0):
            TN += 1
    if((TP + FP + TN) == 0):
        return -1
    result = TP / (TP + FP + TN)
    return round(result, 3)
